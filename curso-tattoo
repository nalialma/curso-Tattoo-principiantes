<script>
// ═══════════════════════════════════════
// QUIZ ENGINE
// ═══════════════════════════════════════
const moduleProgress = {
  modulo1: false, modulo2: false, modulo3: false,
  modulo4: false, modulo5: false, modulo6: false
};

// Track selected answers per quiz
const quizAnswers = {};

function initQuiz(quizId) {
  quizAnswers[quizId] = {};
  const questions = document.querySelectorAll(`#${quizId} .question-block, #quizForm${quizId.slice(-1)} .question-block`);
  // Use the form ID instead
}

// Option selection
document.querySelectorAll('.options-list').forEach(list => {
  list.querySelectorAll('.option-item').forEach(item => {
    item.addEventListener('click', function() {
      // Find which quiz this belongs to
      const qBlock = this.closest('.question-block');
      const quizSection = this.closest('[id^="quiz"]');
      if (!quizSection) return;
      const quizId = quizSection.id;
      const qNum = qBlock.getAttribute('data-q');

      // Deselect siblings
      list.querySelectorAll('.option-item').forEach(i => {
        i.classList.remove('selected');
        i.querySelector('.option-indicator').textContent = i.getAttribute('data-val').toUpperCase();
      });

      // Select this
      this.classList.add('selected');
      this.querySelector('.option-indicator').textContent = '●';

      // Store answer
      if (!quizAnswers[quizId]) quizAnswers[quizId] = {};
      quizAnswers[quizId][qNum] = this.getAttribute('data-val');

      // Check if all questions answered to enable submit
      const form = document.getElementById('quizForm' + quizId.replace('quiz',''));
      if (!form) return;
      const totalQs = form.querySelectorAll('.question-block').length;
      const answered = Object.keys(quizAnswers[quizId]).length;
      const submitBtn = document.getElementById('submitQuiz' + quizId.replace('quiz',''));
      if (submitBtn && answered >= totalQs) {
        submitBtn.disabled = false;
      }
    });
  });
});

function submitQuiz(quizId, correctAnswers, nextModuleId, resultId, requiredPct = 80) {
  const num = quizId.replace('quiz','');
  const form = document.getElementById('quizForm' + num);
  const resultDiv = document.getElementById('result' + num);
  const answers = quizAnswers[quizId] || {};
  const totalQs = form.querySelectorAll('.question-block').length;

  // Check all answered
  if (Object.keys(answers).length < totalQs) {
    alert('Respondé todas las preguntas antes de enviar.');
    return;
  }

  // Show correct/wrong
  let correct = 0;
  form.querySelectorAll('.question-block').forEach(qBlock => {
    const qNum = qBlock.getAttribute('data-q');
    const correctVal = correctAnswers[qNum];
    const selectedVal = answers[qNum];
    qBlock.querySelectorAll('.option-item').forEach(item => {
      const val = item.getAttribute('data-val');
      if (val === correctVal) {
        item.classList.add('correct');
        item.querySelector('.option-indicator').textContent = '✓';
      }
      if (val === selectedVal && val !== correctVal) {
        item.classList.add('wrong');
        item.querySelector('.option-indicator').textContent = '✗';
      }
    });
    if (selectedVal === correctVal) correct++;
  });

  const pct = Math.round((correct / totalQs) * 100);
  const pass = pct >= requiredPct;

  // Disable submit
  document.getElementById('submitQuiz' + num).disabled = true;
  document.getElementById('submitQuiz' + num).style.opacity = '0.5';

  // Show result
  resultDiv.className = `quiz-result ${pass ? 'pass' : 'fail'}`;
  document.getElementById('resultIcon' + num).textContent = pass ? '🏆' : '💀';
  document.getElementById('resultScore' + num).textContent = pct + '%';
  document.getElementById('resultScore' + num).style.color = pass ? '#00ff88' : 'var(--red)';
  document.getElementById('resultTitle' + num).textContent = pass ? '¡APROBADO!' : 'NO APROBADO';
  document.getElementById('resultTitle' + num).style.color = pass ? '#00ff88' : 'var(--red)';

  const reqMsg = requiredPct === 100 ? '100% requerido' : '80% mínimo';
  document.getElementById('resultText' + num).textContent = pass
    ? `Respondiste ${correct} de ${totalQs} correctamente (${pct}%). ¡Excelente trabajo!`
    : `Respondiste ${correct} de ${totalQs} correctamente (${pct}%). Se requiere ${reqMsg}. Repasá el material e intentá de nuevo.`;

  const actionDiv = document.getElementById('resultAction' + num);
  if (pass) {
    if (nextModuleId) {
      actionDiv.innerHTML = `<button class="unlock-btn" onclick="unlockModule('${nextModuleId}', ${num})">DESBLOQUEAR MÓDULO ${parseInt(num)+1} →</button>`;
    } else {
      actionDiv.innerHTML = `<div style="font-family:'Bebas Neue',sans-serif;font-size:32px;color:var(--yellow);letter-spacing:3px;margin-top:20px;">🎓 ¡CURSO TEÓRICO COMPLETADO!</div><div style="font-size:13px;color:rgba(255,255,255,0.6);margin-top:12px;line-height:1.8;">Ahora empieza la parte práctica: piel sintética → frutas → personas bajo supervisión.</div>`;
      updateProgress(6);
    }
  } else {
    actionDiv.innerHTML = `<button class="retry-btn" onclick="retryQuiz('${quizId}', '${num}')">VOLVER A INTENTAR</button>`;
  }

  resultDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
  if (pass && nextModuleId) {
    moduleProgress[nextModuleId.replace('#','')] = true;
    updateProgress(parseInt(num));
  }
}

function unlockModule(moduleId, currentNum) {
  const section = document.getElementById(moduleId);
  if (!section) return;
  section.classList.remove('locked');
  updateProgress(parseInt(currentNum));
  updateDots(parseInt(currentNum));
  setTimeout(() => {
    section.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 300);
}

function retryQuiz(quizId, num) {
  const form = document.getElementById('quizForm' + num);
  const resultDiv = document.getElementById('result' + num);
  const submitBtn = document.getElementById('submitQuiz' + num);

  // Reset options
  form.querySelectorAll('.option-item').forEach(item => {
    item.classList.remove('selected', 'correct', 'wrong');
    item.querySelector('.option-indicator').textContent = item.getAttribute('data-val').toUpperCase();
  });

  // Clear answers
  quizAnswers[quizId] = {};

  // Hide result, re-enable form
  resultDiv.className = 'quiz-result';
  submitBtn.disabled = true;
  submitBtn.style.opacity = '1';

  form.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// ═══════════════════════════════════════
// PROGRESS
// ═══════════════════════════════════════
function updateProgress(completedModule) {
  const total = 6;
  const fill = document.getElementById('progressFill');
  const pct = document.getElementById('progressPct');
  const pctVal = Math.round((completedModule / total) * 100);
  fill.style.width = pctVal + '%';
  pct.textContent = pctVal + '%';
}

function updateDots(completedModule) {
  const dots = document.querySelectorAll('.module-dot');
  dots.forEach((dot, i) => {
    if (i < completedModule) {
      dot.classList.add('done');
      dot.classList.remove('active');
    } else if (i === completedModule) {
      dot.classList.add('active');
      dot.classList.remove('done');
    }
  });
}

// ═══════════════════════════════════════
// CHECKLIST TOGGLE
// ═══════════════════════════════════════
function toggleCheck(el) {
  el.classList.toggle('checked');
  const box = el.querySelector('.check-box');
  if (el.classList.contains('checked')) {
    box.textContent = '✓';
  } else {
    box.textContent = '';
  }
}

// ═══════════════════════════════════════
// SCROLL REVEAL
// ═══════════════════════════════════════
const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1 });

document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// ═══════════════════════════════════════
// PHOTO HOVER TEXT
// ═══════════════════════════════════════
document.querySelectorAll('.photo-item').forEach(item => {
  item.style.cssText += '; position:relative;';
});

// Create hover overlay via CSS is handled above
// Add cursor pointer
document.querySelectorAll('.photo-item').forEach(item => {
  item.addEventListener('click', function() {
    // Could open modal in production
    this.style.opacity = this.style.opacity === '0.7' ? '1' : '0.7';
  });
});
</script>
</body>
