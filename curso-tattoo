<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>INKACADEMY — Curso de Tatuaje</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700;900&family=IBM+Plex+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0a0a0a;
    --white: #f5f0e8;
    --yellow: #FFE600;
    --red: #FF2400;
    --ink: #1a1a2e;
    --border: 3px solid #0a0a0a;
    --border-thick: 5px solid #0a0a0a;
    --shadow: 6px 6px 0px #0a0a0a;
    --shadow-big: 10px 10px 0px #0a0a0a;
    --shadow-yellow: 6px 6px 0px #FFE600;
    --shadow-red: 6px 6px 0px #FF2400;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--white);
    color: var(--black);
    font-family: 'Space Mono', monospace;
    overflow-x: hidden;
    cursor: crosshair;
  }

  /* NOISE TEXTURE OVERLAY */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.5;
  }

  /* ═══════════════════════════════════════
     HEADER / HERO
  ═══════════════════════════════════════ */
  .hero {
    background: var(--black);
    color: var(--white);
    min-height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr auto;
    border-bottom: var(--border-thick);
    position: relative;
    overflow: hidden;
  }

  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(120px, 25vw, 340px);
    color: rgba(255,255,255,0.04);
    white-space: nowrap;
    pointer-events: none;
    letter-spacing: -10px;
    line-height: 1;
  }

  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 40px;
    border-bottom: var(--border);
    border-color: rgba(245,240,232,0.2);
    position: relative;
    z-index: 10;
  }

  .nav-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    color: var(--yellow);
    letter-spacing: 4px;
    text-decoration: none;
    border: var(--border);
    border-color: var(--yellow);
    padding: 4px 16px;
  }

  .nav-badge {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: rgba(245,240,232,0.6);
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px 40px;
    position: relative;
    z-index: 10;
  }

  .hero-tag {
    display: inline-block;
    background: var(--red);
    color: var(--white);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 6px 14px;
    border: var(--border);
    border-color: var(--white);
    margin-bottom: 30px;
    width: fit-content;
    animation: blink 2s infinite;
  }

  @keyframes blink {
    0%, 90%, 100% { opacity: 1; }
    95% { opacity: 0; }
  }

  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(70px, 14vw, 200px);
    line-height: 0.88;
    letter-spacing: -2px;
    margin-bottom: 40px;
  }

  .hero-title span {
    display: block;
    color: var(--yellow);
    -webkit-text-stroke: 2px var(--yellow);
  }

  .hero-title em {
    display: block;
    font-style: normal;
    -webkit-text-stroke: 2px var(--white);
    color: transparent;
  }

  .hero-desc {
    font-size: 14px;
    line-height: 1.8;
    max-width: 520px;
    color: rgba(245,240,232,0.75);
    border-left: 4px solid var(--yellow);
    padding-left: 20px;
    margin-bottom: 50px;
  }

  .hero-cta {
    display: inline-block;
    background: var(--yellow);
    color: var(--black);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 3px;
    padding: 16px 50px;
    border: var(--border-thick);
    border-color: var(--yellow);
    text-decoration: none;
    box-shadow: var(--shadow-yellow);
    transition: all 0.15s;
    cursor: pointer;
  }

  .hero-cta:hover {
    transform: translate(-4px, -4px);
    box-shadow: 10px 10px 0px var(--yellow);
  }

  .hero-cta:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0px var(--yellow);
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: var(--border);
    border-color: rgba(245,240,232,0.15);
    position: relative;
    z-index: 10;
  }

  .stat-item {
    padding: 30px 40px;
    border-right: var(--border);
    border-color: rgba(245,240,232,0.15);
  }

  .stat-item:last-child { border-right: none; }

  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 56px;
    color: var(--yellow);
    line-height: 1;
  }

  .stat-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: rgba(245,240,232,0.5);
    margin-top: 4px;
  }

  /* ═══════════════════════════════════════
     MARQUEE
  ═══════════════════════════════════════ */
  .marquee-wrap {
    background: var(--yellow);
    border-top: var(--border-thick);
    border-bottom: var(--border-thick);
    overflow: hidden;
    padding: 12px 0;
  }

  .marquee-track {
    display: flex;
    gap: 0;
    animation: marquee 18s linear infinite;
    white-space: nowrap;
  }

  .marquee-track span {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 4px;
    padding: 0 40px;
    color: var(--black);
  }

  .marquee-track span::after {
    content: '✦';
    margin-left: 40px;
    color: var(--red);
  }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ═══════════════════════════════════════
     ADVERTENCIA BANNER
  ═══════════════════════════════════════ */
  .warning-banner {
    background: var(--red);
    color: var(--white);
    border-bottom: var(--border-thick);
    padding: 30px 40px;
    display: flex;
    align-items: flex-start;
    gap: 24px;
  }

  .warning-icon {
    font-size: 48px;
    flex-shrink: 0;
    line-height: 1;
  }

  .warning-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    letter-spacing: 2px;
    margin-bottom: 8px;
  }

  .warning-text {
    font-size: 13px;
    line-height: 1.7;
    opacity: 0.9;
  }

  /* ═══════════════════════════════════════
     SECTIONS SHARED
  ═══════════════════════════════════════ */
  section {
    border-bottom: var(--border-thick);
  }

  .section-header {
    display: flex;
    align-items: stretch;
    border-bottom: var(--border-thick);
  }

  .section-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 80px;
    line-height: 1;
    padding: 20px 30px;
    background: var(--black);
    color: var(--yellow);
    border-right: var(--border-thick);
    min-width: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .section-title-wrap {
    padding: 24px 40px;
    flex: 1;
  }

  .section-eyebrow {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 8px;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1;
    letter-spacing: 1px;
  }

  .section-body {
    padding: 50px 40px;
  }

  /* ═══════════════════════════════════════
     LOCK OVERLAY
  ═══════════════════════════════════════ */
  .module {
    position: relative;
  }

  .module.locked .module-inner {
    filter: blur(3px);
    pointer-events: none;
    user-select: none;
  }

  .lock-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10,10,10,0.85);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 50;
    display: none;
  }

  .module.locked .lock-overlay {
    display: flex;
  }

  .lock-box {
    background: var(--yellow);
    border: var(--border-thick);
    box-shadow: var(--shadow-big);
    padding: 40px 50px;
    text-align: center;
    max-width: 480px;
  }

  .lock-icon {
    font-size: 64px;
    margin-bottom: 16px;
    display: block;
  }

  .lock-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 42px;
    letter-spacing: 2px;
    margin-bottom: 12px;
    color: var(--black);
  }

  .lock-desc {
    font-size: 13px;
    color: var(--black);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .lock-btn {
    background: var(--black);
    color: var(--yellow);
    border: var(--border-thick);
    border-color: var(--black);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 3px;
    padding: 12px 36px;
    cursor: pointer;
    box-shadow: var(--shadow);
    transition: all 0.15s;
  }

  .lock-btn:hover {
    transform: translate(-3px,-3px);
    box-shadow: var(--shadow-big);
  }

  /* ═══════════════════════════════════════
     CONTENT CARDS
  ═══════════════════════════════════════ */
  .topic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 0;
    border: var(--border-thick);
  }

  .topic-card {
    padding: 28px 24px;
    border-right: var(--border-thick);
    border-bottom: var(--border-thick);
    transition: background 0.15s;
  }

  .topic-card:hover { background: var(--yellow); }

  .topic-card-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 48px;
    color: rgba(10,10,10,0.12);
    line-height: 1;
    margin-bottom: 8px;
  }

  .topic-card:hover .topic-card-num { color: rgba(10,10,10,0.2); }

  .topic-card-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }

  .topic-card-text {
    font-size: 12px;
    line-height: 1.7;
    color: rgba(10,10,10,0.65);
  }

  .topic-card:hover .topic-card-text { color: var(--black); }

  /* ═══════════════════════════════════════
     VIDEO PLACEHOLDER
  ═══════════════════════════════════════ */
  .media-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: var(--border-thick);
    margin-bottom: 30px;
  }

  .media-item {
    position: relative;
    border-right: var(--border-thick);
    border-bottom: var(--border-thick);
    overflow: hidden;
    cursor: pointer;
  }

  .media-item:last-child { border-right: none; }

  .media-thumb {
    width: 100%;
    aspect-ratio: 16/9;
    background: var(--black);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--white);
    transition: background 0.2s;
    position: relative;
    overflow: hidden;
  }

  .media-thumb::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 10px,
      rgba(255,255,255,0.02) 10px,
      rgba(255,255,255,0.02) 20px
    );
  }

  .media-item:hover .media-thumb { background: #1a1a1a; }

  .media-play {
    width: 60px;
    height: 60px;
    background: var(--yellow);
    border: var(--border-thick);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    margin-bottom: 14px;
    box-shadow: var(--shadow);
    transition: all 0.15s;
    position: relative;
    z-index: 2;
  }

  .media-item:hover .media-play {
    transform: translate(-2px,-2px);
    box-shadow: var(--shadow-big);
  }

  .media-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0.7;
    position: relative;
    z-index: 2;
  }

  .media-duration {
    position: absolute;
    bottom: 10px;
    right: 10px;
    background: var(--red);
    color: var(--white);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    padding: 2px 8px;
    font-weight: 700;
    border: 2px solid var(--white);
    z-index: 2;
  }

  /* FOTO PLACEHOLDERS */
  .photo-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: var(--border-thick);
    margin-bottom: 30px;
  }

  .photo-item {
    aspect-ratio: 1;
    background: var(--black);
    border-right: var(--border-thick);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32px;
    color: rgba(255,255,255,0.15);
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.2s;
  }

  .photo-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 8px,
      rgba(255,230,0,0.05) 8px,
      rgba(255,230,0,0.05) 16px
    );
  }

  .photo-item:hover { background: #111; }
  .photo-item:hover::after {
    content: 'VER FOTO';
    position: absolute;
    inset: 0;
    background: rgba(255,230,0,0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 3px;
    color: var(--black);
  }

  .photo-item:last-child { border-right: none; }

  .photo-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--yellow);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 4px 8px;
    color: var(--black);
    font-weight: 700;
    border-top: 2px solid var(--black);
    z-index: 2;
  }

  /* ═══════════════════════════════════════
     INFOGRAFÍA / DIAGRAMA
  ═══════════════════════════════════════ */
  .info-box {
    background: var(--black);
    color: var(--white);
    border: var(--border-thick);
    padding: 36px;
    margin-bottom: 30px;
    box-shadow: var(--shadow-big);
  }

  .info-box-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    color: var(--yellow);
    letter-spacing: 2px;
    margin-bottom: 24px;
    border-bottom: 2px solid rgba(255,255,255,0.1);
    padding-bottom: 16px;
  }

  .skin-diagram {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0;
    border: 2px solid rgba(255,255,255,0.1);
  }

  .skin-layer {
    display: contents;
  }

  .skin-layer-label {
    padding: 16px 20px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 2px;
    border-bottom: 2px solid rgba(255,255,255,0.1);
    border-right: 2px solid rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    min-width: 160px;
  }

  .skin-layer-content {
    padding: 16px 20px;
    font-size: 12px;
    line-height: 1.7;
    border-bottom: 2px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.75);
  }

  .layer-epi .skin-layer-label { background: #3d2b1f; color: #f4a26a; }
  .layer-derm .skin-layer-label { background: #1f2b1f; color: var(--yellow); }
  .layer-hypo .skin-layer-label { background: #1f1f3d; color: #8aabff; }

  /* NEEDLE CONFIG TABLE */
  .needle-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }

  .needle-table th {
    background: var(--yellow);
    color: var(--black);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 2px;
    padding: 12px 16px;
    text-align: left;
    border: var(--border);
  }

  .needle-table td {
    padding: 10px 16px;
    border: var(--border);
    background: var(--white);
    vertical-align: top;
    line-height: 1.6;
  }

  .needle-table tr:nth-child(even) td { background: #ede8e0; }

  .needle-code {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 700;
    font-size: 14px;
    color: var(--red);
  }

  /* ═══════════════════════════════════════
     QUIZ / EXAMEN
  ═══════════════════════════════════════ */
  .quiz-section {
    background: var(--black);
    color: var(--white);
    padding: 50px 40px;
    border-top: var(--border-thick);
  }

  .quiz-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 40px;
  }

  .quiz-badge {
    background: var(--red);
    color: var(--white);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 3px;
    padding: 8px 20px;
    border: var(--border);
    border-color: var(--white);
    flex-shrink: 0;
  }

  .quiz-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 48px;
    line-height: 1;
  }

  .quiz-subtitle {
    font-size: 12px;
    color: rgba(255,255,255,0.5);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 4px;
  }

  .quiz-rule {
    background: rgba(255,230,0,0.1);
    border: 2px solid var(--yellow);
    padding: 16px 20px;
    margin-bottom: 36px;
    font-size: 12px;
    line-height: 1.7;
    color: var(--yellow);
  }

  .quiz-rule strong {
    display: block;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 2px;
    margin-bottom: 4px;
  }

  .question-block {
    margin-bottom: 36px;
    padding: 28px;
    border: 2px solid rgba(255,255,255,0.1);
    transition: border-color 0.2s;
  }

  .question-block.answered { border-color: rgba(255,255,255,0.25); }

  .question-num {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--red);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .question-text {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-bottom: 20px;
    line-height: 1.4;
  }

  .options-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .option-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 18px;
    border: 2px solid rgba(255,255,255,0.15);
    cursor: pointer;
    transition: all 0.15s;
    font-size: 13px;
    line-height: 1.5;
  }

  .option-item:hover {
    border-color: var(--yellow);
    background: rgba(255,230,0,0.08);
  }

  .option-item.selected {
    border-color: var(--yellow);
    background: rgba(255,230,0,0.12);
    color: var(--yellow);
  }

  .option-item.correct {
    border-color: #00ff88;
    background: rgba(0,255,136,0.1);
    color: #00ff88;
  }

  .option-item.wrong {
    border-color: var(--red);
    background: rgba(255,36,0,0.1);
    color: var(--red);
  }

  .option-indicator {
    width: 28px;
    height: 28px;
    border: 2px solid currentColor;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 16px;
    flex-shrink: 0;
    transition: all 0.15s;
  }

  .quiz-submit {
    background: var(--yellow);
    color: var(--black);
    border: var(--border-thick);
    border-color: var(--yellow);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 4px;
    padding: 18px 60px;
    cursor: pointer;
    box-shadow: var(--shadow-yellow);
    transition: all 0.15s;
    display: block;
    margin: 0 auto;
  }

  .quiz-submit:hover {
    transform: translate(-4px,-4px);
    box-shadow: 10px 10px 0px var(--yellow);
  }

